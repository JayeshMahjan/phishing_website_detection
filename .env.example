# ============================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control!

# Flask Secret Key (required for flash messages)
# Generate a strong random key for production
SECRET_KEY=your-secret-key-change-this-in-production

# Email Configuration (for sending welcome emails)
# Gmail SMTP Settings (recommended)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# Your Gmail credentials
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# Default sender name and email
MAIL_DEFAULT_SENDER="PhishGuard AI <noreply@phishguard.ai>"

# Groq API Key for Chatbot
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
